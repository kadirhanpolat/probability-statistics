% =====================================================================
%  TEOREM ORTAMLARI  (bolum numarasina gore numaralanir)
% =====================================================================

\theoremstyle{definition}
\newtheorem{tanim}{Tanım}[chapter]
\newtheorem{ornek}[tanim]{Örnek}
\newtheorem{aksiyom}[tanim]{Aksiyom}

\theoremstyle{plain}
\newtheorem{teorem}[tanim]{Teorem}
\newtheorem{onerme}[tanim]{Önerme}
\newtheorem{lemma}[tanim]{Lemma}
\newtheorem{sonuc}[tanim]{Sonuç}

\theoremstyle{remark}
\newtheorem*{uyari}{Uyarı}
\newtheorem*{notkutu}{Not}
\newtheorem*{tarihselnot}{Tarihsel Not}

% İspat sonu sembolü
\renewcommand{\qedsymbol}{$\blacksquare$}

% =====================================================================
%  GENEL MATEMATİK MAKROLARI
% =====================================================================

% Sayı kümeleri
\newcommand{\R}{\mathbb{R}}          % gerçel sayılar
\newcommand{\N}{\mathbb{N}}          % doğal sayılar
\newcommand{\Z}{\mathbb{Z}}          % tam sayılar
\newcommand{\Q}{\mathbb{Q}}          % rasyonel sayılar
\newcommand{\C}{\mathbb{C}}          % karmaşık sayılar
\newcommand{\Rbar}{\overline{\mathbb{R}}}  % genişletilmiş gerçel sayılar

% Küme operasyonları
\newcommand{\powerset}[1]{\mathcal{P}(#1)}   % kuvvet kümesi
\newcommand{\inv}{^{-1}}                       % ters
\newcommand{\restr}[1]{\!\restriction_{#1}}   % kısıtlama
\newcommand{\eqdef}{\vcentcolon=}             % tanım eşitliği

% Limit notasyonu (LaTeX'te tanımlı olduğundan renewcommand gerekli)
\renewcommand{\limsup}{\varlimsup}
\renewcommand{\liminf}{\varliminf}

% =====================================================================
%  ÖLÇÜM TEORİSİ MAKROLARI
% =====================================================================

\newcommand{\sigalg}{\mathcal{F}}              % σ-cebiri (genel)
\newcommand{\Borel}{\mathcal{B}}               % Borel σ-cebiri
\newcommand{\borelR}{\mathcal{B}(\mathbb{R})}  % R üzerinde Borel
\newcommand{\mustar}{\mu^{*}}                  % dış ölçü
\newcommand{\leb}{\lambda}                     % Lebesgue ölçüsü

% =====================================================================
%  OLASILIK TEORİSİ MAKROLARI
% =====================================================================

% Temel notasyon
\newcommand{\Prob}{\mathbb{P}}                 % olasılık ölçüsü  P(A)
\newcommand{\Beklenti}{\mathbb{E}}             % beklenti  E[X]
\newcommand{\Var}{\operatorname{Var}}          % varyans
\newcommand{\Cov}{\operatorname{Cov}}          % kovaryans
\newcommand{\Cor}{\operatorname{Cor}}          % korelasyon
\newcommand{\SD}{\operatorname{SD}}            % standart sapma

% Olasılık uzayı bileşenleri
\newcommand{\ornekuzay}{\Omega}                % örnek uzay Ω
\newcommand{\olas}[1]{(\Omega,\mathcal{F},#1)} % (Ω, F, P) üçlüsü

% Rasgele değişken notasyonu
\newcommand{\ddf}{F}                           % dağılım fonksiyonu F_X
\newcommand{\ydv}{f}                           % yoğunluk fonksiyonu f_X
\newcommand{\gostf}[1]{\mathbbm{1}_{#1}}       % gösterge fonksiyonu 1_A

% Dağılım fonksiyonları
\newcommand{\CF}{\varphi}                      % karakteristik fonksiyon φ_X(t)
\newcommand{\MGF}{M}                           % moment üreten fonksiyon M_X(t)
\newcommand{\PGF}{G}                           % olasılık üreten fonksiyon G_X(t)

% Yakınsama türleri
\newcommand{\asto}{\xrightarrow{\text{n.k.}}}      % neredeyse kesin → a.s.
\newcommand{\pto}{\xrightarrow{\mathbb{P}}}         % olasılıkla →
\newcommand{\dto}{\xrightarrow{d}}                  % dağılımla →
\newcommand{\Lpto}[1]{\xrightarrow{L^{#1}}}        % L^p'de →
\newcommand{\iid}{\overset{\text{i.i.d.}}{\sim}}   % bağımsız özdeş dağılımlı

% Dağılım sembolleri
\newcommand{\Normal}{\mathcal{N}}              % normal dağılım N(μ,σ²)
\newcommand{\Uniform}{\mathcal{U}}             % düzgün dağılım U(a,b)
\newcommand{\Exp}{\operatorname{Exp}}          % üstel dağılım
\newcommand{\Gama}{\operatorname{Gama}}        % gama dağılım
\newcommand{\Beta}{\operatorname{Beta}}        % beta dağılım
\newcommand{\Binom}{\operatorname{Bin}}        % binom dağılım
\newcommand{\Pois}{\operatorname{Pois}}        % Poisson dağılım
\newcommand{\Geom}{\operatorname{Geom}}        % geometrik dağılım
\newcommand{\Bernoulli}{\operatorname{Ber}}    % Bernoulli dağılım
\newcommand{\Chisq}{\chi^2}                    % ki-kare dağılım

% Eşitsizlikler ve önemli sabitler
\newcommand{\eqd}{\overset{d}{=}}             % dağılım eşitliği

% =====================================================================
%  MATEMATİKSEL İSTATİSTİK MAKROLARI
% =====================================================================

% Tahmin ve çıkarım
\newcommand{\tahmin}[1]{\hat{#1}}              % tahmin edici \hat{θ}
\newcommand{\MLE}[1]{\hat{#1}_{\text{MLE}}}   % MLE tahmini
\newcommand{\UMVUE}[1]{\hat{#1}_{\text{BVTY}}} % UMVUE / BVTY
\newcommand{\bias}{\operatorname{Bias}}        % yanlılık
\newcommand{\MSE}{\operatorname{MSE}}          % ortalama kare hata
\newcommand{\risk}{\operatorname{R}}           % risk fonksiyonu

% Olabilirlik
\newcommand{\Likh}{L}                          % olabilirlik L(θ|x)
\newcommand{\logLikh}{\ell}                    % log-olabilirlik ℓ(θ|x)
\newcommand{\Fisher}{\mathcal{I}}              % Fisher bilgisi I(θ)
\newcommand{\score}{S}                         % skor fonksiyonu

% İstatistiksel test
\newcommand{\Hifir}{H_0}                       % sıfır hipotezi
\newcommand{\Hbir}{H_1}                        % alternatif hipotez
\newcommand{\reject}{\mathcal{R}}              % ret bölgesi
\newcommand{\guc}{\beta}                       % güç fonksiyonu
\newcommand{\boyut}{\alpha}                    % test boyutu (tip I hata)

% Örneklem istatistikleri
\newcommand{\Xbar}{\bar{X}}                    % örneklem ortalaması
\newcommand{\xbar}{\bar{x}}
\newcommand{\Svar}{S^2}                        % örneklem varyansı

% Regresyon
\newcommand{\EKK}{\operatorname{EKK}}          % en küçük kareler
\newcommand{\bhat}{\hat{\boldsymbol{\beta}}}   % EKK tahmini

