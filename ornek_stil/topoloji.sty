\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{topoloji}[2026/05/27 v0.1 Topoloji kitabi matematik makrolari ve teorem ortamlari]

\RequirePackage{amsmath}
\RequirePackage{amsthm}
\RequirePackage{mathtools}

% ---- Turkce teorem ortamlari ----
\theoremstyle{definition}
\newtheorem{tanim}{Tanım}[chapter]
\newtheorem{ornek}[tanim]{Örnek}
\newtheorem{problem}[tanim]{Problem}

\theoremstyle{plain}
\newtheorem{teorem}[tanim]{Teorem}
\newtheorem{onerme}[tanim]{Önerme}
\newtheorem{lemma}[tanim]{Lemma}
\newtheorem{sonuc}[tanim]{Sonuç}

\theoremstyle{remark}
\newtheorem*{uyari}{Uyarı}
\newtheorem*{notkutu}{Not}

% ispat sonu kutusu Turkce
\renewcommand{\qedsymbol}{$\blacksquare$}

% ---- Sik kullanilan kume/topoloji makrolari ----
\newcommand{\R}{\mathbb{R}}
\newcommand{\N}{\mathbb{N}}
\newcommand{\Z}{\mathbb{Z}}
\newcommand{\Q}{\mathbb{Q}}
\newcommand{\C}{\mathbb{C}}
\newcommand{\powerset}[1]{\mathcal{P}(#1)}
\newcommand{\topo}{\tau}                      % topoloji
\newcommand{\acik}{\tau}                       % acik kume ailesi
\DeclareMathOperator{\ic}{i\!c}                % interior (gerekirse)
\newcommand{\kapanis}[1]{\overline{#1}}        % kapanis
\newcommand{\Ic}[1]{\operatorname{Int}(#1)}    % ic
\newcommand{\Sinir}[1]{\partial #1}            % sinir
\newcommand{\restr}[1]{\!\restriction_{#1}}    % kisitlama
\newcommand{\inv}{^{-1}}
\newcommand{\eqdef}{\vcentcolon=}

